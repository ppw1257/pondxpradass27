<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prada SS27 Comment Picker</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #fff;
      color: #111;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .shell { width: 100%; max-width: 500px; }
    .eyebrow {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .eyebrow::before, .eyebrow::after {
      content: '';
      flex: 1;
      height: 0.5px;
      background: #e0e0e0;
    }
    .headline {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 400;
      color: #111;
      text-align: center;
      margin-bottom: 0.3rem;
      line-height: 1.15;
    }
    .headline em { font-style: italic; }
    .sub {
      font-size: 12px;
      color: #aaa;
      text-align: center;
      letter-spacing: 0.08em;
      margin-bottom: 2rem;
    }
    .stats-row {
      display: flex;
      gap: 6px;
      justify-content: center;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }
    .stat {
      font-size: 11px;
      color: #999;
      background: #f7f7f6;
      border-radius: 999px;
      padding: 4px 12px;
    }
    .stat span { color: #111; font-weight: 500; }
    .card {
      background: #fff;
      border: 0.5px solid #e0e0e0;
      border-radius: 12px;
      padding: 1.75rem 1.5rem 1.5rem;
      margin-bottom: 1rem;
      min-height: 130px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 0.85rem;
    }
    .qmark {
      font-family: 'Playfair Display', serif;
      font-size: 52px;
      line-height: 0.5;
      color: #ddd;
      align-self: flex-start;
      user-select: none;
      display: none;
    }
    .comment-text {
      font-size: 15px;
      color: #aaa;
      text-align: center;
      line-height: 1.7;
    }
    .comment-text.active { color: #111; font-size: 16px; }
    .tag-row {
      display: flex;
      gap: 6px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1.75rem;
    }
    .tag {
      font-size: 11px;
      letter-spacing: 0.05em;
      padding: 4px 11px;
      border-radius: 999px;
      border: 0.5px solid #e0e0e0;
      color: #aaa;
      background: #f7f7f6;
    }
    .tag.on { border-color: #bbb; color: #555; }
    .btn-row {
      display: flex;
      gap: 10px;
      justify-content: center;
      align-items: center;
    }
    .btn-pick {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.06em;
      padding: 12px 30px;
      border-radius: 8px;
      background: #111;
      color: #fff;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn-pick:hover { opacity: 0.82; }
    .btn-pick:active { transform: scale(0.97); }
    .btn-copy {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      padding: 11px 18px;
      border-radius: 8px;
      background: transparent;
      color: #555;
      border: 0.5px solid #bbb;
      cursor: pointer;
      display: none;
      align-items: center;
      gap: 6px;
      transition: background 0.15s;
    }
    .btn-copy:hover { background: #f7f7f6; }
    .btn-copy.show { display: flex; }
    .gen-bar {
      margin-top: 1.75rem;
      border-top: 0.5px solid #e0e0e0;
      padding-top: 1.25rem;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .gen-info { font-size: 12px; color: #aaa; line-height: 1.6; }
    .gen-info strong { color: #555; font-weight: 500; display: block; margin-bottom: 2px; }
    .btn-gen {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      padding: 9px 16px;
      border-radius: 8px;
      background: transparent;
      color: #555;
      border: 0.5px solid #bbb;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.15s;
    }
    .btn-gen:hover { background: #f7f7f6; }
    .btn-gen:disabled { opacity: 0.4; cursor: not-allowed; }
    .progress {
      height: 2px;
      background: #eee;
      border-radius: 1px;
      margin-top: 0.85rem;
      overflow: hidden;
      display: none;
    }
    .progress-bar {
      height: 100%;
      background: #555;
      border-radius: 1px;
      width: 0%;
      transition: width 0.3s ease;
    }
    .hashtag-box {
      margin-top: 1.5rem;
      border-top: 0.5px solid #e0e0e0;
      padding-top: 1.25rem;
    }
    .hashtag-label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 0.65rem;
    }
    .hashtag-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .pill {
      font-size: 12px;
      padding: 5px 13px;
      border-radius: 999px;
      border: 0.5px solid #e0e0e0;
      color: #555;
      background: #f7f7f6;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
      user-select: none;
    }
    .pill:hover { background: #eee; border-color: #bbb; }
    .pill.copied { background: #111; color: #fff; border-color: #111; }
    .copy-all-btn {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      margin-top: 0.75rem;
      padding: 8px 16px;
      border-radius: 8px;
      background: transparent;
      color: #555;
      border: 0.5px solid #bbb;
      cursor: pointer;
      transition: background 0.15s;
    }
    .copy-all-btn:hover { background: #f7f7f6; }
    @keyframes fadein {
      from { opacity: 0; transform: translateY(5px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-in { animation: fadein 0.3s ease-out; }
  </style>
</head>
<body>
  <div class="shell">
    <p class="eyebrow">Prada · Milan · SS27</p>
    <h1 class="headline">Comment <em>picker</em></h1>
    <p class="sub">Pond Naravit at Milan Fashion Show</p>

    <div class="stats-row">
      <div class="stat">Pool: <span id="pool-count">0</span></div>
      <div class="stat">Picked: <span id="pick-count">0</span></div>
      <div class="stat">Remaining: <span id="remain-count">0</span></div>
    </div>

    <div class="card">
      <div class="qmark" id="qmark">"</div>
      <p class="comment-text" id="result">Generate comments first, then pick</p>
    </div>

    <div class="tag-row">
      <span class="tag" id="tag-tone">—</span>
      <span class="tag" id="tag-num">—</span>
    </div>

    <div class="btn-row">
      <button class="btn-pick" id="btn-pick" onclick="pick()" disabled>&#8635; Pick a comment</button>
      <button class="btn-copy" id="copy-btn" onclick="copyIt()">&#10697; <span id="copy-label">Copy with hashtags</span></button>
    </div>

    <div class="hashtag-box">
      <p class="hashtag-label">Instagram hashtags</p>
      <div class="hashtag-pills">
        <span class="pill" onclick="copyPill(this, '#PradaSS27xPond')">#PradaSS27xPond</span>
        <span class="pill" onclick="copyPill(this, '#ppnaravit')">#ppnaravit</span>
        <span class="pill" onclick="copyPill(this, '#PradaSS27')">#PradaSS27</span>
        <span class="pill" onclick="copyPill(this, '#Prada')">#Prada</span>
        <span class="pill" onclick="copyPill(this, '#PondNaravit')">#PondNaravit</span>
      </div>
      <button class="copy-all-btn" onclick="copyAllHashtags()">&#10697; Copy all hashtags</button>
    </div>

    <div class="gen-bar">
      <div class="gen-info">
        <strong id="gen-status">Ready to generate</strong>
        Click to generate 500 comments. Keep clicking to grow the pool to 10,000+.
      </div>
      <button class="btn-gen" id="btn-gen" onclick="generateBatch()">&#10024; Generate 500</button>
    </div>
    <div class="progress" id="progress">
      <div class="progress-bar" id="progress-bar"></div>
    </div>
  </div>

  <script>
    let pool = [];
    let used = new Set();
    let pickCount = 0;
    let selected = null;
    let batchNum = 0;
    let generating = false;

    const TONES = ["Praising Prada","Adoring Pond","Grateful Fan","Brand Love","Pure Pride","Emotional","Iconic Moment"];

    const EMOJIS = ["🖤","✨","🔥","🇹🇭","🇮🇹","💫","👑","🙌","💯","😍","🌍","🫶","🙏","💕","🤍","🖤✨","🇹🇭✨","💯🖤","👑✨","🙏🖤","🔥🖤","✨🇹🇭","🌟","💎","🫰"];

    const PRADA_PRAISE = [
      "Prada has always defined what luxury means",
      "Prada's legacy speaks for itself",
      "The house of Prada sets the standard every season",
      "Prada's vision is unlike anything else in fashion",
      "No brand carries prestige quite like Prada",
      "Prada continues to lead the fashion world with grace",
      "Prada's craftsmanship and taste are second to none",
      "The Prada universe is one of elegance and intention",
      "Prada has always understood true sophistication",
      "The brilliance of Prada never stops inspiring us",
      "Prada remains the pinnacle of Italian fashion excellence",
      "There is a reason the whole world looks to Prada every season",
      "Prada's eye for beauty is simply unmatched",
      "Prada proves season after season why they are the greatest",
      "The world of Prada is built on excellence and nothing less",
    ];

    const POND_PRAISE = [
      "Pond Naravit is everything a fashion icon should be",
      "Pond Naravit carries himself with an elegance that is rare and real",
      "The presence of Pond Naravit is impossible to ignore",
      "Pond Naravit radiates a charm that the camera simply cannot contain",
      "Pond Naravit is the definition of effortless grace",
      "There is something magnetic about Pond Naravit that draws every eye",
      "Pond Naravit's beauty goes far beyond what words can describe",
      "Pond Naravit belongs in the highest rooms of fashion and tonight proved it",
      "The elegance Pond Naravit brings is timeless and extraordinary",
      "Pond Naravit made every single moment at Milan unforgettable",
      "Pond Naravit is not just handsome — he is a genuine icon",
      "The world is finally seeing what Thailand has always known about Pond Naravit",
      "Pond Naravit's style, grace, and presence are on another level entirely",
      "Watching Pond Naravit at Milan Fashion Week is watching greatness in motion",
      "Pond Naravit is the kind of person that fashion was invented for",
    ];

    const GRATITUDE = [
      "thank you Prada for choosing Pond Naravit",
      "thank you Prada for seeing what we see in Pond Naravit",
      "thank you Prada for giving Pond Naravit this stage",
      "thank you Prada for inviting Pond Naravit to SS27",
      "thank you Prada for recognizing that Pond Naravit belongs here",
      "thank you Prada for making this dream real for Pond Naravit and all of us",
      "thank you Prada for placing Pond Naravit exactly where he deserves to be",
      "we are so grateful to Prada for choosing Pond Naravit for SS27 Milan",
      "Prada we thank you from the bottom of our hearts for Pond Naravit",
      "from every fan: thank you Prada for believing in Pond Naravit",
    ];

    const LOCATION = [
      "at Prada SS27 Milan",
      "at Milan Fashion Week SS27",
      "at the Prada SS27 show in Milan",
      "on the front row at Prada Milan",
      "at Prada Milan Fashion Week",
      "at SS27 in Milan",
      "at the Prada show in Milan",
      "at Prada SS27",
    ];

    const STRUCTURES = [
      () => `${rnd(PRADA_PRAISE)} — and ${rnd(GRATITUDE)} ${rnd(LOCATION)} {e}`,
      () => `${rnd(POND_PRAISE)} ${rnd(LOCATION)} — ${rnd(GRATITUDE)} {e}`,
      () => `${cap(rnd(GRATITUDE))} ${rnd(LOCATION)}. ${rnd(POND_PRAISE)} {e}`,
      () => `${rnd(PRADA_PRAISE)}, and Pond Naravit proved it ${rnd(LOCATION)} — ${rnd(GRATITUDE)} {e}`,
      () => `${rnd(POND_PRAISE)}. ${cap(rnd(GRATITUDE))} ${rnd(LOCATION)} {e}`,
      () => `Dear Prada: ${rnd(GRATITUDE)} ${rnd(LOCATION)}. ${rnd(POND_PRAISE)} {e}`,
      () => `${rnd(PRADA_PRAISE)}. That is why we ${rnd(GRATITUDE)} ${rnd(LOCATION)} {e}`,
      () => `We are in awe of Pond Naravit ${rnd(LOCATION)}, and ${rnd(GRATITUDE)} for this moment {e}`,
      () => `${cap(rnd(GRATITUDE))} ${rnd(LOCATION)}. The world now sees that ${rnd(POND_PRAISE).toLowerCase()} {e}`,
      () => `${rnd(PRADA_PRAISE)}, just as Pond Naravit showed us all ${rnd(LOCATION)} {e}`,
    ];

    function rnd(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
    function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    function generateBatch() {
      if (generating) return;
      generating = true;
      batchNum++;

      const btn = document.getElementById('btn-gen');
      btn.disabled = true;
      btn.textContent = 'Generating…';

      const prog = document.getElementById('progress');
      const bar = document.getElementById('progress-bar');
      prog.style.display = 'block';
      bar.style.width = '5%';
      document.getElementById('gen-status').textContent = 'Generating batch ' + batchNum + '…';

      const seen = new Set(pool.map(c => c.text));
      const batch = [];
      let attempts = 0;
      const target = 500;

      function step() {
        const chunk = 50;
        for (let i = 0; i < chunk && batch.length < target; i++) {
          attempts++;
          const fn = rnd(STRUCTURES);
          let text = fn().replace('{e}', Math.random() > 0.3 ? rnd(EMOJIS) : '').trim();
          text = text.replace(/\s+/g, ' ');
          if (!seen.has(text)) { seen.add(text); batch.push({ text, tone: rnd(TONES) }); }
          if (attempts > target * 20) break;
        }

        const pct = Math.min(95, Math.round((batch.length / target) * 95));
        bar.style.width = pct + '%';

        if (batch.length < target && attempts <= target * 20) {
          setTimeout(step, 0);
        } else {
          pool = pool.concat(batch);
          bar.style.width = '100%';
          setTimeout(() => { prog.style.display = 'none'; bar.style.width = '0%'; }, 500);
          updateStats();
          document.getElementById('btn-pick').disabled = false;
          document.getElementById('gen-status').textContent = 'Batch ' + batchNum + ' done — ' + batch.length + ' comments added';
          btn.disabled = false;
          btn.textContent = '✨ Generate 500 more';
          generating = false;
        }
      }

      setTimeout(step, 50);
    }

    function updateStats() {
      document.getElementById('pool-count').textContent = pool.length.toLocaleString();
      document.getElementById('pick-count').textContent = pickCount;
      document.getElementById('remain-count').textContent = (pool.length - used.size).toLocaleString();
    }

    function pick() {
      if (!pool.length) return;
      if (used.size >= pool.length) used.clear();
      let idx;
      do { idx = Math.floor(Math.random() * pool.length); } while (used.has(idx));
      used.add(idx);
      selected = pool[idx];
      pickCount++;

      const el = document.getElementById('result');
      el.classList.remove('animate-in');
      void el.offsetWidth;
      el.textContent = selected.text;
      el.className = 'comment-text active animate-in';
      document.getElementById('qmark').style.display = 'block';
      document.getElementById('tag-tone').textContent = selected.tone;
      document.getElementById('tag-tone').className = 'tag on';
      document.getElementById('tag-num').textContent = '#' + pickCount;
      document.getElementById('tag-num').className = 'tag on';
      document.getElementById('copy-btn').classList.add('show');
      document.getElementById('copy-label').textContent = 'Copy with hashtags';
      updateStats();
    }

    const HASHTAGS = '#PradaSS27xPond #ppnaravit #PradaSS27 #Prada #PondNaravit';

    // ── Clipboard helper (fixed for mobile & non-secure contexts) ──
    function legacyCopy(text) {
      return new Promise(function(resolve) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.cssText = 'position:fixed;top:0;left:0;width:2em;height:2em;opacity:0;pointer-events:none';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        ta.setSelectionRange(0, 99999);
        try { document.execCommand('copy'); } catch(e) { console.warn('execCommand copy failed', e); }
        document.body.removeChild(ta);
        resolve();
      });
    }

    function copyText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text).catch(function() {
          return legacyCopy(text);
        });
      }
      return legacyCopy(text);
    }
    // ───────────────────────────────────────────────────────────────

    function copyIt() {
      if (!selected) return;
      var full = selected.text + '\n\n' + HASHTAGS;
      copyText(full).then(function() {
        document.getElementById('copy-label').textContent = 'Copied!';
        setTimeout(function() {
          document.getElementById('copy-label').textContent = 'Copy with hashtags';
        }, 1800);
      });
    }

    function copyPill(el, tag) {
      copyText(tag).then(function() {
        el.classList.add('copied');
        var orig = el.textContent;
        el.textContent = '✓ Copied';
        setTimeout(function() { el.textContent = orig; el.classList.remove('copied'); }, 1500);
      });
    }

    function copyAllHashtags() {
      copyText(HASHTAGS).then(function() {
        var btn = document.querySelector('.copy-all-btn');
        var orig = btn.textContent;
        btn.textContent = '✓ Copied!';
        setTimeout(function() { btn.textContent = orig; }, 1800);
      });
    }
  </script>
</body>
</html>
